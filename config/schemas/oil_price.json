{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "国内油价数据",
  "description": "国家发改委公布的国内成品油价格数据",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "error"],
      "description": "数据状态"
    },
    "data": {
      "type": "object",
      "properties": {
        "update_time": {
          "type": "string",
          "format": "date-time",
          "description": "数据更新时间"
        },
        "prices": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "fuel_type": {
                "type": "string",
                "enum": ["92号汽油", "95号汽油", "98号汽油", "0号柴油"],
                "description": "燃油类型"
              },
              "price": {
                "type": "number",
                "minimum": 0,
                "maximum": 20,
                "description": "价格（元/升）"
              },
              "change": {
                "type": "number",
                "description": "价格变动（元/升）"
              },
              "change_percent": {
                "type": "number",
                "minimum": -100,
                "maximum": 100,
                "description": "价格变动百分比"
              },
              "unit": {
                "type": "string",
                "default": "元/升",
                "description": "价格单位"
              }
            },
            "required": ["fuel_type", "price"]
          },
          "minItems": 1,
          "description": "油价列表"
        },
        "province": {
          "type": "string",
          "description": "省份（如适用）"
        },
        "effective_date": {
          "type": "string",
          "format": "date",
          "description": "生效日期"
        }
      },
      "required": ["update_time", "prices"]
    },
    "metadata": {
      "type": "object",
      "properties": {
        "source": {
          "type": "string",
          "description": "数据来源"
        },
        "collected_at": {
          "type": "string",
          "format": "date-time",
          "description": "采集时间"
        },
        "version": {
          "type": "string",
          "description": "数据版本"
        },
        "quality_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "数据质量评分"
        },
        "fields_count": {
          "type": "integer",
          "minimum": 0,
          "description": "字段数量"
        },
        "records_count": {
          "type": "integer",
          "minimum": 0,
          "description": "记录数量"
        }
      },
      "required": ["source", "collected_at", "version", "quality_score"]
    }
  },
  "required": ["status", "data", "metadata"]
}