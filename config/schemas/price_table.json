{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "价格表数据",
  "description": "各类商品和服务价格数据",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "error"],
      "description": "数据状态"
    },
    "data": {
      "type": "object",
      "properties": {
        "update_time": {
          "type": "string",
          "format": "date-time",
          "description": "数据更新时间"
        },
        "prices": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "category": {
                "type": "string",
                "description": "商品类别"
              },
              "name": {
                "type": "string",
                "description": "商品名称"
              },
              "price": {
                "type": "number",
                "minimum": 0,
                "description": "价格"
              },
              "unit": {
                "type": "string",
                "description": "价格单位"
              },
              "currency": {
                "type": "string",
                "default": "CNY",
                "description": "货币类型"
              },
              "change": {
                "type": "number",
                "description": "价格变动"
              },
              "change_percent": {
                "type": "number",
                "description": "价格变动百分比"
              },
              "region": {
                "type": "string",
                "description": "地区"
              },
              "brand": {
                "type": "string",
                "description": "品牌"
              },
              "specification": {
                "type": "string",
                "description": "规格"
              }
            },
            "required": ["category", "name", "price", "unit"]
          },
          "description": "价格列表"
        }
      },
      "required": ["update_time", "prices"]
    },
    "metadata": {
      "type": "object",
      "properties": {
        "source": {
          "type": "string",
          "description": "数据来源"
        },
        "collected_at": {
          "type": "string",
          "format": "date-time",
          "description": "采集时间"
        },
        "version": {
          "type": "string",
          "description": "数据版本"
        },
        "quality_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "数据质量评分"
        },
        "fields_count": {
          "type": "integer",
          "minimum": 0,
          "description": "字段数量"
        },
        "records_count": {
          "type": "integer",
          "minimum": 0,
          "description": "记录数量"
        }
      },
      "required": ["source", "collected_at", "version", "quality_score"]
    }
  },
  "required": ["status", "data", "metadata"]
}