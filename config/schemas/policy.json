{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "政策信息数据",
  "description": "国家及地方政策法规数据",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "error"],
      "description": "数据状态"
    },
    "data": {
      "type": "object",
      "properties": {
        "update_time": {
          "type": "string",
          "format": "date-time",
          "description": "数据更新时间"
        },
        "policies": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string",
                "description": "政策标题"
              },
              "category": {
                "type": "string",
                "description": "政策类别"
              },
              "issuing_authority": {
                "type": "string",
                "description": "发布机构"
              },
              "publish_date": {
                "type": "string",
                "format": "date",
                "description": "发布日期"
              },
              "effective_date": {
                "type": "string",
                "format": "date",
                "description": "生效日期"
              },
              "content_summary": {
                "type": "string",
                "description": "内容摘要"
              },
              "document_number": {
                "type": "string",
                "description": "文号"
              },
              "url": {
                "type": "string",
                "format": "uri",
                "description": "原文链接"
              }
            },
            "required": ["title", "category", "publish_date"]
          },
          "description": "政策列表"
        }
      },
      "required": ["update_time", "policies"]
    },
    "metadata": {
      "type": "object",
      "properties": {
        "source": {
          "type": "string",
          "description": "数据来源"
        },
        "collected_at": {
          "type": "string",
          "format": "date-time",
          "description": "采集时间"
        },
        "version": {
          "type": "string",
          "description": "数据版本"
        },
        "quality_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "数据质量评分"
        },
        "fields_count": {
          "type": "integer",
          "minimum": 0,
          "description": "字段数量"
        },
        "records_count": {
          "type": "integer",
          "minimum": 0,
          "description": "记录数量"
        }
      },
      "required": ["source", "collected_at", "version", "quality_score"]
    }
  },
  "required": ["status", "data", "metadata"]
}